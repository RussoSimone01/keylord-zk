{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"AllowedHosts": "*",
	"ConnectionStrings": {
		"Default": ""
	},
	"Jwt": {
		"Secret": "",
		"Issuer": "keylord-zk",
		"Audience": "keylord-zk-client",
		"AccessTokenExpiryMinutes": 15,
		"RefreshTokenExpiryDays": 7
	},
	"Cors": {
		"AllowedOrigin": ""
	},
	"IpRateLimiting": {
		"EnableEndpointRateLimiting": true,
		"StackBlockedRequests": false,
		"HttpStatusCode": 429,
		"GeneralRules": [
			{
				"Endpoint": "POST:/api/auth/register",
				"Period": "1m",
				"Limit": 5
			},
			{
				"Endpoint": "POST:/api/auth/login",
				"Period": "1m",
				"Limit": 10
			},
			{
				"Endpoint": "GET:/api/auth/salt/*",
				"Period": "1m",
				"Limit": 10
			}
		]
	}
}
